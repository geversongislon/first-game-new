; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="FIRST GAME NEW"
run/main_scene="uid://df7k3m2n1p0q"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

CardDatabase="*res://scripts/managers/card_database.gd"
LoadoutManager="*res://scripts/managers/loadout_manager.gd"
GameManager="*res://scripts/managers/game_manager.gd"
SceneManager="*res://scripts/managers/scene_manager.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/texture_filter="nearest"

[gui]

theme/custom="res://resources/ui/default_theme.tres"

